---
// src/pages/index.astro
import { getCollection } from 'astro:content';
import '../styles/global.css';

const lessons = await getCollection('lessons');
lessons.sort((a, b) => a.data.chapter - b.data.chapter);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Deep Learning from Scratch</title>
    <meta name="description" content="Tensors, autodiff, gradient descent, CNNs — built from first principles in C++. A complete deep learning framework course with interactive diagrams." />
    <meta property="og:title" content="Deep Learning from Scratch" />
    <meta property="og:description" content="Tensors, autodiff, gradient descent, CNNs — built from first principles in C++." />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="hero">
      <h1>Deep Learning<br />from Scratch</h1>
      <p class="subtitle">
        Tensors, autodiff, gradient descent, CNNs — built from first principles
        in C++. These notes are the understanding that came out the other side.
      </p>
      <a href="/lessons/01-tensors" class="cta">Start with Tensors →</a>
    </div>

    <div class="chapter-grid">
      {lessons.map(lesson => (
        <a href={`/lessons/${lesson.id}`} class="chapter-card">
          <div class="chapter-num">
            {String(lesson.data.chapter).padStart(2, '0')}
          </div>
          <h3>{lesson.data.title}</h3>
          <p>{lesson.data.description}</p>
        </a>
      ))}
    </div>
  </body>
</html>
