---
// src/layouts/LessonLayout.astro
import SidebarNav from '../components/SidebarNav.astro';
import { getCollection } from 'astro:content';
import '../styles/global.css';

interface Props {
  title: string;
  chapter: number;
  description: string;
}

const { title, chapter, description } = Astro.props;

// Get lesson list for sidebar current chapter highlighting
const allLessons = await getCollection('lessons');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} — Deep Learning from Scratch`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <title>{title} — Deep Learning from Scratch</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="progress-bar" id="progress-bar"></div>
    <div class="layout">
      <aside class="sidebar">
        <div class="sidebar-title">Deep Learning<br />from Scratch</div>
        <SidebarNav currentChapter={chapter} />
      </aside>
      <main class="main-content">
        <slot />
      </main>
    </div>
    <script>
      const bar = document.getElementById('progress-bar');
      if (bar) {
        window.addEventListener('scroll', () => {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
          bar.style.width = progress + '%';
        });
      }
    </script>
  </body>
</html>
