---
import UnlockManager from '../shared/UnlockManager.astro';
---

<UnlockManager featureId="ch10-attention-heatmap" triggerText="Compute attention weights...">
  <div class="attention-demo">
    <div class="controls">
      <div class="control-group">
        <label for="text-input">Input text (5-20 chars):</label>
        <input
          id="text-input"
          type="text"
          placeholder="The quick"
          value="The quick"
          maxlength="20"
          class="text-input"
        />
      </div>

      <div class="control-group">
        <label for="head-select">Attention head:</label>
        <select id="head-select" class="select">
          <option value="0">Head 0</option>
          <option value="1">Head 1</option>
          <option value="2">Head 2</option>
          <option value="3">Head 3</option>
        </select>
      </div>

      <div class="control-group">
        <button id="compute-btn" class="compute-button">Compute Attention</button>
        <span id="status" class="status">Loading model...</span>
      </div>
    </div>

    <div class="heatmap-container">
      <div id="heatmap" class="heatmap"></div>
    </div>

    <div class="explanation">
      <p>
        <strong>What you're looking at:</strong> Each cell shows how much attention
        the model pays to each key token when generating each query token.
      </p>
      <p>
        <strong>Dark/bright cells:</strong> Bright = strong attention, dark = weak attention.
        Notice how tokens often attend to themselves and nearby neighbors.
      </p>
    </div>
  </div>
</UnlockManager>

<script>
  import { AttentionHeatmapDemo } from '../../../js/demos/ch10/attention-heatmap';

  const demo = new AttentionHeatmapDemo();
  let modelLoaded = false;

  const textInput = document.getElementById('text-input') as HTMLInputElement;
  const headSelect = document.getElementById('head-select') as HTMLSelectElement;
  const computeBtn = document.getElementById('compute-btn') as HTMLButtonElement;
  const statusSpan = document.getElementById('status') as HTMLElement;
  const heatmapDiv = document.getElementById('heatmap') as HTMLElement;

  // Load Plotly for heatmap visualization
  const loadPlotly = async () => {
    if (typeof (window as any).Plotly !== 'undefined') {
      return;
    }
    const script = document.createElement('script');
    script.src = 'https://cdn.plot.ly/plotly-2.26.0.min.js';
    script.async = true;
    document.head.appendChild(script);
    await new Promise((resolve) => {
      script.onload = resolve;
    });
  };

  // Initialize
  (async () => {
    try {
      await loadPlotly();
      await demo.loadModel();
      modelLoaded = true;
      statusSpan.textContent = '✓ Ready';
      statusSpan.classList.add('ready');
      computeBtn.disabled = false;
    } catch (error) {
      statusSpan.textContent = 'Error loading model';
      statusSpan.classList.add('error');
      console.error('Failed to load Transformer model:', error);
    }
  })();

  // Compute button handler
  computeBtn.addEventListener('click', async () => {
    if (!modelLoaded) return;

    const text = textInput.value.trim();
    if (!text) {
      statusSpan.textContent = 'Enter some text';
      return;
    }

    const head = parseInt(headSelect.value);

    computeBtn.disabled = true;
    statusSpan.textContent = 'Computing...';

    try {
      // Determine dark mode
      const isDarkMode =
        window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;

      // Get heatmap data
      const heatmapData = await demo.getHeatmapData(text, 0, head, isDarkMode);

      // Prepare Plotly trace
      const { data, layout } = demo.preparePlotlyTrace(heatmapData, isDarkMode);

      // Render heatmap
      (window as any).Plotly.newPlot(heatmapDiv, data, layout, {
        responsive: true,
        displayModeBar: false,
      });

      statusSpan.textContent = '✓ Ready';
    } catch (error) {
      statusSpan.textContent = `Error: ${error}`;
      console.error('Attention computation failed:', error);
    } finally {
      computeBtn.disabled = false;
    }
  });
</script>

<style>
  .attention-demo {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: 1.5rem;
    background: var(--card-bg);
    border-radius: 8px;
    border: 1px solid var(--border-color);
  }

  .controls {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .control-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .control-group label {
    font-weight: 500;
    font-size: 0.95rem;
  }

  .text-input,
  .select {
    padding: 0.75rem;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    font-size: 1rem;
    background: var(--input-bg);
    color: var(--text-color);
    font-family: monospace;
  }

  .compute-button {
    padding: 0.75rem 1.5rem;
    background: var(--accent-color);
    color: white;
    border: none;
    border-radius: 4px;
    font-weight: 600;
    cursor: pointer;
    font-size: 1rem;
    transition: background 0.2s;
  }

  .compute-button:hover:not(:disabled) {
    opacity: 0.9;
  }

  .compute-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .status {
    font-size: 0.9rem;
    padding: 0.5rem;
    border-radius: 4px;
    background: var(--status-bg);
    color: var(--status-text);
  }

  .status.ready {
    background: rgba(34, 197, 94, 0.1);
    color: #22c55e;
  }

  .status.error {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
  }

  .heatmap-container {
    display: flex;
    justify-content: center;
    overflow-x: auto;
  }

  .heatmap {
    min-width: 400px;
    min-height: 400px;
  }

  .explanation {
    font-size: 0.95rem;
    line-height: 1.6;
    padding: 1rem;
    background: var(--quote-bg);
    border-left: 4px solid var(--accent-color);
    border-radius: 4px;
  }

  .explanation p {
    margin: 0.5rem 0;
  }

  @media (prefers-color-scheme: dark) {
    .text-input,
    .select {
      background: #1f2937;
      color: #e5e7eb;
      border-color: #374151;
    }

    .status {
      background: #374151;
      color: #9ca3af;
    }

    .compute-button {
      background: #3b82f6;
    }

    .explanation {
      background: #1f2937;
      border-left-color: #3b82f6;
    }
  }

  @media (prefers-color-scheme: light) {
    .text-input,
    .select {
      background: #ffffff;
      color: #1f2937;
      border-color: #e5e7eb;
    }

    .status {
      background: #f3f4f6;
      color: #6b7280;
    }

    .compute-button {
      background: #2563eb;
    }

    .explanation {
      background: #f9fafb;
      border-left-color: #2563eb;
    }
  }

  @media (max-width: 768px) {
    .attention-demo {
      padding: 1rem;
    }

    .heatmap {
      min-width: 300px;
      min-height: 300px;
    }
  }
</style>
