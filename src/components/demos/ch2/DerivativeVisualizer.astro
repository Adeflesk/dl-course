---
import WasmDemo from '../../WasmDemo.astro';

interface Props {
    demoId?: string;
}

const { demoId = 'ch2-derivative-viz' } = Astro.props;
---

<WasmDemo
    title="Derivative Visualizer"
    description="Explore how derivatives represent the slope of a function. Select a function and drag the slider to see f(x), f'(x), and the tangent line."
    demoId={demoId}
>
    <div slot="demo" class="derivative-demo">
        <div class="controls">
            <div class="control-group">
                <label for="function-select">Function:</label>
                <select id="function-select">
                    <option value="x2">f(x) = x²</option>
                    <option value="sin">f(x) = sin(x)</option>
                    <option value="x3">f(x) = x³</option>
                    <option value="exp">f(x) = eˣ</option>
                    <option value="log">f(x) = ln(x)</option>
                    <option value="x4">f(x) = x⁴</option>
                </select>
            </div>

            <div class="control-group">
                <label for="x-slider">x value:</label>
                <input
                    type="range"
                    id="x-slider"
                    min="-5"
                    max="5"
                    step="0.01"
                    value="0"
                />
            </div>

            <div class="control-group">
                <label for="x-display">x:</label>
                <input
                    type="number"
                    id="x-display"
                    step="0.01"
                    value="0"
                    readonly
                />
            </div>
        </div>

        <div class="canvas-container">
            <canvas id="derivative-canvas" width="600" height="400"></canvas>
        </div>

        <div class="metrics">
            <div class="metric">
                <span class="metric-label">f(x):</span>
                <span class="metric-value" id="fx-value">0.00</span>
            </div>
            <div class="metric">
                <span class="metric-label">f'(x):</span>
                <span class="metric-value" id="fpx-value">0.00</span>
            </div>
            <div class="metric">
                <span class="metric-label">Tangent slope:</span>
                <span class="metric-value" id="slope-value">0.00</span>
            </div>
        </div>
    </div>
</WasmDemo>

<style>
.derivative-demo {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.controls {
    display: flex;
    gap: 1rem;
    align-items: flex-end;
    padding: 1rem;
    background: #f5f9ff;
    border-radius: 6px;
    flex-wrap: wrap;
}

.control-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 0 1 auto;
}

.control-group label {
    font-size: 0.9rem;
    font-weight: 500;
    color: #333;
}

.control-group select,
.control-group input[type='range'],
.control-group input[type='number'] {
    padding: 0.4rem 0.6rem;
    border: 1px solid #4a90e2;
    border-radius: 4px;
    font-size: 0.9rem;
    background: white;
    color: #333;
}

.control-group select {
    cursor: pointer;
}

.control-group input[type='range'] {
    min-width: 150px;
    padding: 0;
    cursor: pointer;
}

.control-group input[type='number'] {
    width: 70px;
    text-align: center;
}

.canvas-container {
    display: flex;
    justify-content: center;
    background: white;
    padding: 1rem;
    border: 1px solid #ddd;
    border-radius: 6px;
    overflow: auto;
}

canvas {
    border: 1px solid #ddd;
    border-radius: 4px;
    display: block;
}

.metrics {
    display: flex;
    gap: 2rem;
    padding: 1rem;
    background: #f5f9ff;
    border-left: 4px solid #4a90e2;
    border-radius: 4px;
}

.metric {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
}

.metric-label {
    font-size: 0.85rem;
    font-weight: 500;
    color: #666;
}

.metric-value {
    font-size: 1.1rem;
    font-weight: 600;
    color: #4a90e2;
    font-family: monospace;
}

@media (prefers-color-scheme: dark) {
    .controls {
        background: #1a2a3a;
    }

    .control-group label {
        color: #b0b0b0;
    }

    .control-group select,
    .control-group input[type='range'],
    .control-group input[type='number'] {
        background: #1e1e1e;
        border-color: #4a90e2;
        color: #b0b0b0;
    }

    .canvas-container {
        background: #1e1e1e;
        border-color: #333;
    }

    canvas {
        border-color: #333;
        background: #1e1e1e;
    }

    .metrics {
        background: #1a2a3a;
        border-left-color: #4a90e2;
    }

    .metric-label {
        color: #808080;
    }

    .metric-value {
        color: #4a9fd8;
    }
}

@media (max-width: 768px) {
    canvas {
        width: 100%;
        height: auto;
    }

    .controls {
        flex-direction: column;
    }

    .control-group {
        width: 100%;
    }

    .control-group input[type='range'] {
        min-width: 100%;
    }

    .metrics {
        flex-direction: column;
        gap: 1rem;
    }
}
</style>

<script>
    import { DerivativeVisualizer, FUNCTIONS } from '../../../js/demos/ch2/derivative-visualizer';

    const canvas = document.getElementById('derivative-canvas') as HTMLCanvasElement;
    const functionSelect = document.getElementById('function-select') as HTMLSelectElement;
    const xSlider = document.getElementById('x-slider') as HTMLInputElement;
    const xDisplay = document.getElementById('x-display') as HTMLInputElement;
    const fxValue = document.getElementById('fx-value') as HTMLSpanElement;
    const fpxValue = document.getElementById('fpx-value') as HTMLSpanElement;
    const slopeValue = document.getElementById('slope-value') as HTMLSpanElement;

    // Initialize visualizer
    const visualizer = new DerivativeVisualizer('derivative-canvas');

    // Draw initial function
    visualizer.drawFunction();
    updateMetrics();

    // Update function when selection changes
    functionSelect.addEventListener('change', (e) => {
        const funcType = (e.target as HTMLSelectElement).value as any;
        visualizer.setFunction(funcType);

        // Update slider range based on function domain
        const funcDef = FUNCTIONS[funcType];
        const [min, max] = funcDef.domain;
        xSlider.min = min.toString();
        xSlider.max = max.toString();
        xSlider.value = ((min + max) / 2).toString();
        xDisplay.value = ((min + max) / 2).toFixed(2);

        updateMetrics();

        // Trigger unlock event on first interaction
        triggerUnlock();
    });

    // Update x value when slider moves
    xSlider.addEventListener('input', (e) => {
        const x = parseFloat((e.target as HTMLInputElement).value);
        visualizer.setX(x);
        xDisplay.value = x.toFixed(2);
        updateMetrics();

        // Trigger unlock event on first interaction
        triggerUnlock();
    });

    // Update x value from number input
    xDisplay.addEventListener('change', (e) => {
        const x = parseFloat((e.target as HTMLInputElement).value);
        const funcDef = FUNCTIONS[visualizer.selectedFunction];
        const [min, max] = funcDef.domain;

        // Clamp value to domain
        const clampedX = Math.max(min, Math.min(max, x));
        xSlider.value = clampedX.toString();
        visualizer.setX(clampedX);
        xDisplay.value = clampedX.toFixed(2);
        updateMetrics();

        // Trigger unlock event on first interaction
        triggerUnlock();
    });

    // Update metric display
    function updateMetrics() {
        const { fx, fpx } = visualizer.getMetrics();
        fxValue.textContent = fx.toFixed(2);
        fpxValue.textContent = fpx.toFixed(2);
        slopeValue.textContent = fpx.toFixed(2);
    }

    // Trigger unlock event for progressive disclosure
    function triggerUnlock() {
        localStorage.setItem('unlock_ch2_debugger', 'true');
        window.dispatchEvent(
            new CustomEvent('unlock', {
                detail: { featureId: 'ch2_debugger' },
            })
        );
    }
</script>
