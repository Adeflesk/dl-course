---
// src/components/SidebarNav.astro
import { getCollection } from 'astro:content';

interface Props {
  currentChapter: number;
}

const { currentChapter } = Astro.props;

// Dynamically load all lesson chapters
const lessons = await getCollection('lessons');
const sortedLessons = lessons.sort((a, b) => a.data.chapter - b.data.chapter);
---

<nav>
  {sortedLessons.map(lesson => (
    <a
      href={`/lessons/${lesson.slug}`}
      class={`nav-item${lesson.data.chapter === currentChapter ? ' active' : ''}`}
    >
      <span class="nav-chapter-num">{String(lesson.data.chapter).padStart(2, '0')}</span>
      {lesson.data.title}
    </a>
  ))}
</nav>
